{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Udfly",
  "version": "1.1.1",
  "identifier": "com.udfly.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Udfly",
        "width": 1100,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "A fast, portable viewer for UYAP .udf documents",
    "longDescription": "A fast, portable viewer for UYAP .udf documents",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["udf"],
        "name": "UDF Document",
        "description": "UYAP Universal Document Format",
        "mimeType": "application/x-udf",
        "role": "Viewer"
      }
    ]
  }
}
