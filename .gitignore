# Dependencies
node_modules/

# Build artifacts
dist/
build/
src-tauri/target/
src-tauri/gen/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Claude Code local config
.claude/settings.local.json

# Playwright MCP cache (transient screenshots / runtime artifacts)
.playwright-mcp/

# Scratch from tools that occasionally write to a Windows absolute path on
# a POSIX-style git view, landing the path itself as a filename in the
# working tree (e.g. "C:UsersfahriAppDataLocalTemp..."). The colon is
# illegal in NTFS filenames, so any file whose name starts with `C:` is
# never legitimate project content.
C:*

# Environment
.env
.env.local
.env.*.local

# Samples
# IMPORTANT: samples/fixtures/ IS committed (sanitized test data).
# samples/private/ is NEVER committed (contains real UDFs with personal data).
# Note: we use `samples/private/*` (not `samples/private/`) so the README
# negation below actually works — git cannot re-include a file whose parent
# directory has been excluded.
samples/private/*
!samples/private/README.md
